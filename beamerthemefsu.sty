% Custom Unofficial Beamerposter Theme: fsutheme

\ProvidesPackage{beamerthemefsu}[2025/04/04 FSU Custom Theme Unofficial]
\RequirePackage{kvoptions}
\RequirePackage{etoolbox}
\RequirePackage[most]{tcolorbox}
\SetupKeyvalOptions{
    family=fsutheme,
    prefix=fsutheme@
}

\DeclareBoolOption[false]{presentation}
\ProcessKeyvalOptions*
% ======================
% Global Bullet Styling
% ======================
\RequirePackage{tikz}
\newcommand{\fsuglowbullet}{
    \tikz[baseline=-0.6ex]{
        \shade[ball color=FSUGarnet] (0,0) circle (0.12cm);
    }
}

\setbeamertemplate{itemize item}{\fsuglowbullet}
\setbeamertemplate{itemize subitem}{
    \tikz[baseline=-0.4ex]{
        \shade[ball color=FSUGarnet] (0,0) circle (0.09 cm);
    }
}

\iffsutheme@presentation
    \RequirePackage[T1]{fontenc}
    \RequirePackage{lmodern}
    \RequirePackage{ragged2e}
    \RequirePackage{xcolor}

    \renewcommand{\familydefault}{\rmdefault}
    \usefonttheme{professionalfonts}

    \setbeamerfont{headline institute}{size=\Large}
    \setbeamerfont{section in toc}{size=\large}
    \setbeamerfont{subsection in toc}{size=\small}
    \setbeamerfont{subsubsection in toc}{size=\tiny}
    \setbeamertemplate{section in toc}[sections numbered]
    \setbeamertemplate{subsection in toc}{
      \leavevmode
      \hspace{1.1em}\fsuglowbullet \hspace{0.2em}\inserttocsubsection\par
    }
\else
% ======================
% Poster Font Setup (Latin Modern Serif)
% ======================
\RequirePackage[T1]{fontenc}
\RequirePackage{lmodern}
\RequirePackage{calc}
\RequirePackage{ragged2e}
\RequirePackage{changepage}
\RequirePackage{pgffor}
\RequirePackage{xcolor}

% FORCE SERIF DEFAULT: This is the missing piece
\renewcommand{\familydefault}{\rmdefault}
\usefonttheme{professionalfonts} 

% ======================
% Default Font Settings
% ======================
\setbeamerfont{headline title}{size=\Huge, series=\bfseries}
\setbeamerfont{headline author}{size=\Large}
\setbeamerfont{headline institute}{size=\normalsize}
\setbeamerfont{block title}{size=\large, series=\bfseries}
\setbeamerfont{heading}{series=\bfseries}
\setbeamerfont{footline}{size=\normalsize}
\setbeamerfont{frametitle}{size=\Large}
\fi 

% ======================
% Logo Management
% ======================
\newcommand{\presentationlogo}[1]{\newcommand{\insertpresentationlogo}{#1}}
\newlength{\logowidth}
\setlength{\logowidth}{10cm}

\newcommand{\logoleft}[1]{\newcommand{\insertlogoleft}{#1}}
\newcommand{\logoright}[1]{\newcommand{\insertlogoright}{#1}}

% ======================
% Header / Title Bar
% ======================
\iffsutheme@presentation

\setbeamertemplate{title page}{
  \begin{center}
    % Title box centered with shadow
    \begin{beamercolorbox}[wd=0.85\paperwidth, rounded=true, shadow=true, center]{title box}
    \usebeamerfont{title}
    \centering
    \parbox{0.8\paperwidth}{\centering\inserttitle}
    \end{beamercolorbox}

    
    \vspace{1cm}
    {\usebeamerfont{author}\insertauthor\par}
    
    \vspace{0.5cm}
    {\usebeamerfont{institute}\insertinstitute\par}
    
    \vspace{0.5cm}
    {\usebeamerfont{date}\insertdate\par}

    \vspace{0.51cm}
    \ifdefined\insertpresentationlogo
      \insertpresentationlogo
    \fi
  \end{center}
}

%=========Presentation Header======= 
\setbeamertemplate{headline}{
  \leavevmode%
  \hbox{%
    \begin{beamercolorbox}[wd=0.5\paperwidth, ht=2.5ex, dp=1.5ex, center]{headline left}%
      \usebeamerfont{section in head/foot}\vfill\insertsectionhead\vfill
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=0.5\paperwidth, ht=2.5ex, dp=1.5ex, center]{headline right}%
      \usebeamerfont{section in head/foot}\vfill
      \ifx\insertframetitle\empty
        % Do nothing
      \else
        \ifnum\value{framenumber}=1
          % Title page: do nothing
        \else
          \ifx\insertframetitle\tableofcontentsname
            % TOC page: do nothing
          \else
            \foreach \n in {\insertsectionstartpage,...,\insertsectionendpage}{
              \ifnum\n=\insertframenumber
                \hyperlink{slide\n}{\raisebox{0ex}{\large$\bullet$}}
              \else
                \hyperlink{slide\n}{\color{gray!60}\raisebox{0ex}{\small$\bullet$}}
              \fi
              \hspace{0.2em}
            }
          \fi
        \fi
      \fi
      \vfill
    \end{beamercolorbox}%
  }
}


\else
%==========Poster Header=======
% Define the default widths
\newlength{\leftlogowidth}
\newlength{\centertitlewidth}
\newlength{\rightlogowidth}
\setlength{\leftlogowidth}{0.2\paperwidth}
\setlength{\centertitlewidth}{0.6\paperwidth}
\setlength{\rightlogowidth}{0.2\paperwidth}

\setbeamertemplate{headline}{
  \begin{beamercolorbox}{headline}
    \begin{columns}
      \begin{column}{\leftlogowidth}
        \ifdefined\insertlogoleft
        \vspace*{0.5ex}
        \raggedright
        \hspace{5ex}
        \insertlogoleft
        \fi
      \end{column}
      \begin{column}{\centertitlewidth}
        \centering
        \vskip2ex
        {\usebeamerfont{headline title} \inserttitle \par}
        \vskip1ex
        {\usebeamerfont{headline author} \insertauthor \par}
        \vskip0.5ex
        {\usebeamerfont{headline institute} \insertinstitute \par}
      \end{column}
      \begin{column}{\rightlogowidth}
        \ifdefined\insertlogoright
        \vspace*{0.5ex}
        \raggedleft 
        \insertlogoright
        \hspace{6ex}
        \fi
      \end{column}
    \end{columns}
    \begin{beamercolorbox}[wd=\paperwidth,ht=1ex]{headline rule}
    \end{beamercolorbox}
  \end{beamercolorbox}
  \vspace{-5ex}
}
\renewcommand{\fsuglowbullet}{
    \tikz[baseline=-0.6ex]{
        \shade[ball color=FSUGarnet] (0,0) circle (0.2cm); % Slightly larger for posters
    }
}
\fi

%==================== frame title ==========================
\setbeamertemplate{frametitle}{
    \vskip-0.62ex
    \begin{beamercolorbox}[
        wd=\paperwidth,
        ht=2.3ex,        % was 3ex
        dp=0.9ex,      % was 1.5ex
        shadow=true,
        leftskip=1.2ex,rightskip=1.2ex
    ]{frametitle}
        \usebeamerfont{frametitle}\insertframetitle
    \end{beamercolorbox}
    \vskip0.5ex
}


% ======================
% Footer Content
% ======================
\iffsutheme@presentation
\setbeamerfont{author in head/foot}{size=\scriptsize}
\setbeamerfont{title in head/foot}{size=\scriptsize}
\setbeamerfont{date in head/foot}{size=\scriptsize}
\setbeamerfont{section in head/foot}{size=\scriptsize}
\setbeamerfont{subsection in head/foot}{size=\scriptsize}
\setbeamerfont{footnote}{size=\tiny}
%==========Presentation footer============
\setbeamertemplate{footline}{

  % ===== Bottom: Custom footer =====
  \leavevmode%
  \hbox{%
    \begin{beamercolorbox}[wd=0.2\paperwidth,ht=2ex,dp=1.5ex,center]{footline left}%
        \centering
        \vspace{-.7 ex}
      \usebeamerfont{section in head/foot} \hspace{1ex}\insertshortauthor
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=0.5\paperwidth,ht=2ex,dp=1.5ex,center]{footline center}%
      \centering
      \vspace{-.7ex}
      \usebeamerfont{section in head/foot}
      \hspace{1ex}\insertshorttitle
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=0.3\paperwidth,ht=2ex,dp=1.5ex,right]{footline right}%
      \centering
      \vspace{-1.2 ex}
      \usebeamerfont{section in head/foot} 
      \insertshortdate{}\hfill%
      \insertframenumber{}/\inserttotalframenumber\hspace{1ex}
    \end{beamercolorbox}%
  }
}

\else 
%=============Poster footer=============
\newcommand{\footercontent}[1]{\newcommand{\insertfootercontent}{#1}}

\setbeamertemplate{footline}{
  \ifdefined\insertfootercontent
  \begin{beamercolorbox}[wd=\paperwidth,ht=2ex,dp=1ex]{footline}
    \usebeamerfont{footline} \insertfootercontent
    \hspace{\sepwidth}
  \end{beamercolorbox}
  \fi
}
\fi

% ======================
% Block Styling
% ======================
\iffsutheme@presentation

\setbeamertemplate{block begin}{
  \begin{beamercolorbox}[wd=0.85\paperwidth,left, rounded=true, shadow=true, ht=1ex, dp=1ex]{block title}
  \vspace{-2ex}
    \usebeamerfont{block title}\insertblocktitle
    \vskip-1.25ex
    \begin{beamercolorbox}{block separator}
    \end{beamercolorbox}
  \end{beamercolorbox}
  \begin{beamercolorbox}[wd=0.85\paperwidth, rounded=true, shadow=true]{block body}
  \justifying
}
\setbeamertemplate{block end}{
  \end{beamercolorbox}
  \vspace*{1ex}
}
   
\else
% ======================
% Corrected Poster Block Styling (Fixed pgfkeys Error)
% ======================
\setbeamertemplate{block begin}{
  \begin{tcolorbox}[
    enhanced,
    colback=FSUWhite,      % Perfect white background
    colframe=FSUGold,      % Thin gold outline
    coltitle=FSUGarnet,     % Title text color
    colbacktitle=FSUGold, % Title background color
    fonttitle=\usebeamerfont{block title},
    title=\insertblocktitle,
    % --- Fixed Rounding Keys ---
    arc=20pt,              % Correct way to set rounded corner radius
    outer arc=20pt,        % Ensures the outer border matches the inner
    boxrule=2pt,         % Thin gold outline width
    % ---------------------------
    titlerule=0pt,
    left=1ex, right=1ex, top=1ex, bottom=1ex, 
    toptitle=.5ex, bottomtitle=.5ex 
  ]
  \justifying
}

\setbeamertemplate{block end}{
  \end{tcolorbox}
  \vspace*{-1ex}
}

% --- Updated Alert and Example Blocks ---
\setbeamertemplate{block alerted begin}{
  \begin{tcolorbox}[enhanced, colback=FSUWhite, colframe=FSUGarnet, coltitle=FSUWhite, colbacktitle=FSUGarnet, 
    fonttitle=\usebeamerfont{block title}, title=\insertblocktitle, arc=15pt, outer arc=15pt, boxrule=1.5pt]
  \justifying
}
\setbeamertemplate{block alerted end}{\end{tcolorbox}\vspace*{2ex}}

\setbeamertemplate{block example begin}{
  \begin{tcolorbox}[enhanced, colback=FSUWhite, colframe=FSUBlack, coltitle=FSUWhite, colbacktitle=FSUBlack, 
    fonttitle=\usebeamerfont{block title}, title=\insertblocktitle, arc=15pt, outer arc=15pt, boxrule=1.5pt]
  \justifying
}
\setbeamertemplate{block example end}{\end{tcolorbox}\vspace*{2ex}}

\fi
%===================== Table and Images===============
\setbeamertemplate{caption}[numbered]
\setbeamertemplate{caption label separator}{:\hspace{0.3em}}
\setbeamertemplate{caption label format}{\insertcaptionname~\insertcaptionnumber\hspace{0.2em}}


\makeatletter
\patchcmd{\beamer@@frametitle}
    {\gdef\insertframetitle}
    {\hypertarget{slide\theframenumber}{}\gdef\insertframetitle}
    {}{}
\makeatother


